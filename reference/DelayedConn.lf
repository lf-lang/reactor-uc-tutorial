target uC;

reactor HighFrequencySource {
    output out: int;
    timer t(1msec);
    state counter: int = 0;
    
    reaction(t) {=
        lf_set(out, self->counter++);
    =}
}

reactor DataSink {
    input in: int;
    
    reaction(in) {=
        printf("Received data: %d\n", in->value);
    =}
}

main reactor {
    source = new HighFrequencySource();
    sink = new DataSink();
    
    @buffer(5)
    source.out -> sink.in after 500msec; 
}